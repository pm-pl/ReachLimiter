{
  "name": "jorgebyte/reachlimiter",
  "description": "An optimized scope violation validator for PocketMine-MP 5.",
  "type": "project",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Jorgebyte",
      "homepage": "https://discord.jorgebyte.com/"
    }
  ],
  "require": {
    "php": "^8.2",
    "pocketmine/pocketmine-mp": "^5.0.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^1.10.0"
  },
  "autoload": {
    "psr-4": {
      "Jorgebyte\\ReachLimiter\\": "src/Jorgebyte/ReachLimiter/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "fix": "php-cs-fixer fix --config=.php-cs-fixer.php --verbose",
    "analyze": "phpstan analyze src --level=max"
  }
}

